# Supabase (chưa dùng ở giai đoạn này — chỉ để sẵn chỗ)
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Kakao Maps JavaScript SDK (developers.kakao.com > 플랫폼 키 > JavaScript 키)
NEXT_PUBLIC_KAKAO_JS_KEY=your-kakao-javascript-key

# Google Gemini API (aistudio.google.com) — dùng cho tính năng giải thích giấy tờ bằng ảnh
# Server-only, KHÔNG thêm tiền tố NEXT_PUBLIC_
GEMINI_API_KEY=your-gemini-api-key

# Supabase service role key (Project Settings > API) — dùng để ghi bảng subscriptions
# (RLS chặn user thường ghi trực tiếp). Server-only, KHÔNG thêm tiền tố NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Google Play Developer API — service account JSON (toàn bộ nội dung file, dạng 1 dòng)
# Tạo tại Google Cloud Console, rồi liên kết ở Play Console > Setup > API access.
# Cần quyền "Xem dữ liệu tài chính" + "Quản lý đơn hàng" cho app com.camnanghan.app
# Server-only, KHÔNG thêm tiền tố NEXT_PUBLIC_
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON={"client_email":"...","private_key":"..."}
